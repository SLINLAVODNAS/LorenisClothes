@model List<LorenisClothes.Models.CarritoItem>

@{
    ViewData["Title"] = "Carrito";
}

<div class="container mt-4">
    <h2 class="fw-bold text-dark mb-4"><i class="bi bi-cart-check me-2"></i>Tu Carrito de Compras</h2>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model != null && Model.Count > 0)
    {
        <div class="row">
            <!-- Lista de Productos -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Producto</th>
                                    <th>Precio</th>
                                    <th style="width: 140px;">Cantidad</th>
                                    <th>Subtotal</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <img src="@item.ImagenUrl" class="rounded" style="width: 55px; height: 55px; object-fit: cover; border: 1px solid #eee;" />
                                                <div class="ms-3">
                                                    <div class="fw-bold text-dark">@item.Nombre</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td>Q @item.Precio.ToString("N2")</td>
                                        <td>
                                            <div class="input-group input-group-sm">
                                                @* Corregido: Ahora apunta a la acción Restar *@
                                                <a asp-controller="Carrito" asp-action="Restar" asp-route-id="@item.ProductoId" class="btn btn-outline-secondary">
                                                    <i class="bi bi-dash"></i>
                                                </a>
                                                <span class="input-group-text bg-white px-3 fw-bold">@item.Cantidad</span>
                                                @* Corregido: Ahora apunta a Agregar *@
                                                <a asp-controller="Carrito" asp-action="Agregar" asp-route-id="@item.ProductoId" class="btn btn-outline-secondary">
                                                    <i class="bi bi-plus"></i>
                                                </a>
                                            </div>
                                        </td>
                                        <td class="fw-bold">Q @((item.Precio * item.Cantidad).ToString("N2"))</td>
                                        <td>
                                            <a asp-action="Eliminar" asp-route-id="@item.ProductoId" class="btn btn-sm btn-light text-danger border-0 rounded-circle" title="Eliminar del carrito">
                                                <i class="bi bi-trash fs-5"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <a asp-controller="Productos" asp-action="Index" class="btn btn-link text-decoration-none p-0 text-secondary">
                        <i class="bi bi-arrow-left"></i> Seguir comprando
                    </a>
                    <a asp-action="Vaciar" class="btn btn-sm btn-outline-danger border-0" onclick="return confirm('¿Vaciar todo el carrito?')">
                        <i class="bi bi-cart-x"></i> Vaciar carrito
                    </a>
                </div>
            </div>

            <!-- Resumen de Pago -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm bg-white border-top border-primary border-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Resumen de Compra</h5>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Subtotal</span>
                            <span class="fw-bold">Q @Model.Sum(x => x.Precio * x.Cantidad).ToString("N2")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Envío (Jalapa)</span>
                            <span class="text-success fw-bold">Gratis</span>
                        </div>
                        <hr class="my-4">
                        <div class="d-flex justify-content-between mb-4">
                            <span class="fs-5 fw-bold">Total</span>
                            <span class="fs-4 fw-bold text-primary">Q @Model.Sum(x => x.Precio * x.Cantidad).ToString("N2")</span>
                        </div>
                        <div class="d-grid gap-2">
                            <a asp-action="Checkout" class="btn btn-primary btn-lg fw-bold shadow-sm">
                                Finalizar Pedido <i class="bi bi-arrow-right ms-2"></i>
                            </a>
                        </div>
                        <div class="text-center mt-3">
                            <small class="text-muted"><i class="bi bi-lock-fill me-1"></i> Compra segura en Loreni's Clothes</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="bg-light d-inline-block p-4 rounded-circle mb-4">
                <i class="bi bi-cart-x display-1 text-muted"></i>
            </div>
            <h3 class="fw-bold text-dark">Tu carrito está vacío</h3>
            <p class="text-muted">Parece que aún no has agregado prendas a tu carrito.</p>
            <a asp-controller="Productos" asp-action="Index" class="btn btn-primary px-5 mt-3 shadow">Ir a ver productos</a>
        </div>
    }
</div>