@model List<LorenisClothes.Models.CarritoItem>

<h1>Carrito de Compras</h1>

@if (Model.Count == 0)
{
    <p>No hay productos en el carrito.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Imagen</th>
                <th>Nombre</th>
                <th>Precio</th>
                <th>Cantidad</th>
                <th>Total</th>
                <th>Acciones</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <img src="@item.ImagenUrl" width="60" />
                    </td>

                    <td>@item.Nombre</td>

                    <td>Q @item.Precio</td>

                    <td>@item.Cantidad</td>

                    <td>
                        Q @(item.Precio * item.Cantidad)
                    </td>

                    <td>
                        <a asp-action="Eliminar"
                               asp-route-id="@item.ProductoId"
                               class="btn btn-danger btn-sm">
                            Eliminar
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-3">

        <a asp-action="Vaciar"
               class="btn btn-warning">
            Vaciar Carrito
        </a>

        <a asp-action="Checkout"
               class="btn btn-success">
            Confirmar pedido
        </a>

    </div>
}