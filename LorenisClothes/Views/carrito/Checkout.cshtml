@model LorenisClothes.Models.Pedido

@{
    ViewData["Title"] = "Finalizar Compra";
}

<h1 class="mb-4">Finalizar Compra</h1>

<div class="row">
    <div class="col-md-6">

        <form asp-action="Checkout" method="post">

            <div class="form-group mb-3">
                <label asp-for="NombreCliente"></label>
                <input asp-for="NombreCliente" class="form-control" />
                <span asp-validation-for="NombreCliente" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Telefono"></label>
                <input asp-for="Telefono" class="form-control" />
                <span asp-validation-for="Telefono" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Direccion"></label>
                <input asp-for="Direccion" class="form-control" />
                <span asp-validation-for="Direccion" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-success">
                Confirmar Pedido
            </button>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}