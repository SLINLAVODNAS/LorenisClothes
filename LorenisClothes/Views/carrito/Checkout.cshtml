@model LorenisClothes.Models.Pedido

@{
    ViewData["Title"] = "Finalizar Pedido";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-person-check me-2"></i>Datos de Entrega</h4>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted">Por favor, completa tus datos para coordinar la entrega en Jalapa.</p>
                    
                    <form asp-action="Checkout" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="NombreCliente" class="form-label fw-bold">Nombre Completo</label>
                            <input asp-for="NombreCliente" class="form-control form-control-lg" placeholder="¿A quién entregamos?" required />
                            <span asp-validation-for="NombreCliente" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Telefono" class="form-label fw-bold">Teléfono / WhatsApp</label>
                                <input asp-for="Telefono" class="form-control form-control-lg" placeholder="Ej: 55554444" required />
                                <span asp-validation-for="Telefono" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Ubicación</label>
                                <select class="form-select form-select-lg" disabled>
                                    <option>Cabecera de Jalapa</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Direccion" class="form-label fw-bold">Dirección Exacta</label>
                            <textarea asp-for="Direccion" class="form-control" rows="3" placeholder="Ej: Barrio San Francisco, frente a la iglesia..." required></textarea>
                            <span asp-validation-for="Direccion" class="text-danger"></span>
                        </div>

                        <div class="bg-light p-3 rounded mb-4">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold">Total a pagar:</span>
                                @if (ViewBag.Total != null)
                                {
                                    <span class="fs-4 fw-bold text-primary">Q @ViewBag.Total.ToString("N2")</span>
                                }
                            </div>
                            <small class="text-muted"><i class="bi bi-info-circle"></i> El pago se realiza al recibir tus prendas.</small>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg fw-bold shadow">
                                <i class="bi bi-whatsapp me-2"></i> Confirmar y enviar a WhatsApp
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Regresar al carrito</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}