@{
    ViewData["Title"] = "Inicio";
}

<div class="text-center py-5">
    <h1 class="display-4 fw-bold text-dark">Bienvenidos a Loreni´s Clothes</h1>
    <p class="lead text-muted">La mejor moda femenina con entrega directa en la cabecera de Jalapa.</p>
    
    <div class="mt-4">
        <img src="https://images.unsplash.com/photo-1441986300917-64674bd600d8?q=80&w=1000&auto=format&fit=crop"
             class="img-fluid rounded shadow-lg"
             style="max-height: 400px; width: 100%; object-fit: cover;"
             alt="Banner Lorenis Clothes">
    </div>

    <div class="row mt-5 g-4">
        <div class="col-md-4">
            <div class="p-3 border rounded bg-light">
                <i class="bi bi-truck fs-1 text-primary"></i>
                <h4 class="mt-2">Entrega Local</h4>
                <p class="small text-muted">Pedidos rápidos en toda la cabecera departamental.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 border rounded bg-light">
                <i class="bi bi-whatsapp fs-1 text-success"></i>
                <h4 class="mt-2">Atención Directa</h4>
                <p class="small text-muted">Confirmamos tu pedido al instante vía WhatsApp.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 border rounded bg-light">
                <i class="bi bi-heart-fill fs-1 text-danger"></i>
                <h4 class="mt-2">Calidad Garantizada</h4>
                <p class="small text-muted">Prendas seleccionadas con el mejor estilo femenino.</p>
            </div>
        </div>
    </div>

    <div class="mt-5">
        <a asp-controller="Productos" asp-action="Index" class="btn btn-primary btn-lg px-5 fw-bold shadow">
            Ver Catálogo de Productos
        </a>
    </div>
</div>