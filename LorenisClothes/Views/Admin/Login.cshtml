<h1>Login Administrador</h1>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}

<form method="post">

    <div class="mb-3">
        <label class="form-label">
            Usuario
        </label>

        <input name="usuario" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">
            Contraseña
        </label>

        <input name="password"
               type="password"
               class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">
        Ingresar
    </button>

</form>