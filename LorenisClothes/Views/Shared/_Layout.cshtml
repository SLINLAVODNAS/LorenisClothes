@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Loreni´s Clothes</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body { background-color: #f4f6f9; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .navbar { background-color: #355c7d; padding: 10px 0; }
        .navbar-brand { color: white !important; font-size: 24px; font-weight: bold; letter-spacing: 1px; }
        .nav-link { color: rgba(255,255,255,0.9) !important; font-weight: 500; padding: 8px 15px !important; transition: 0.3s; }
        .nav-link:hover { color: white !important; background-color: rgba(255,255,255,0.1); border-radius: 5px; }
        .main-container { margin-top: 30px; background: white; padding: 30px; border-radius: 15px; box-shadow: 0px 4px 15px rgba(0,0,0,0.05); min-height: 75vh; }
        footer { margin-top: 50px; text-align: center; color: #6c757d; padding: 30px 0; border-top: 1px solid #dee2e6; }
        .btn-primary { background-color: #355c7d; border: none; }
        .btn-primary:hover { background-color: #2c4d69; }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark shadow-sm sticky-top">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-gem me-2"></i>Loreni´s Clothes
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index"><i class="bi bi-house-door"></i> Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Productos" asp-action="Index"><i class="bi bi-bag"></i> Catálogo</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link position-relative" asp-controller="Carrito" asp-action="Index">
                            <i class="bi bi-cart3"></i> Carrito
                        </a>
                    </li>

                    @if (Context.Session.GetString("Admin") != null)
                    {
                        <li class="nav-item border-start ms-lg-2 ps-lg-2">
                            <a class="nav-link" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-graph-up"></i> Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Pedidos" asp-action="Index"><i class="bi bi-clipboard-check"></i> Pedidos</a>
                        </li>
                        <li class="nav-item ms-lg-3">
                            <a class="btn btn-outline-light btn-sm px-3" asp-controller="Admin" asp-action="Logout">
                                <i class="bi bi-box-arrow-right"></i> Salir
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item ms-lg-3">
                            <a class="nav-link text-warning border border-warning rounded px-3" asp-controller="Admin" asp-action="Login">
                                <i class="bi bi-person-lock"></i> Acceso Admin
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="main-container">
            @RenderBody()
        </div>
    </div>

    <footer>
        <div class="container">
            <p class="mb-1 fw-bold">© 2026 - Loreni´s Clothes</p>
            <p class="mb-0 small text-muted">Jalapa, Guatemala | <i class="bi bi-whatsapp"></i> +502 4555-6147</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>