@model LorenisClothes.Models.Pedido

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Detalles del Pedido #@Model.Id</h2>
        <a asp-action="Index" class="btn btn-outline-dark">Volver a Pedidos</a>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-dark text-white fw-bold">
                    Datos del Cliente
                </div>
                <div class="card-body">
                    <p class="mb-1"><strong>Nombre:</strong> @Model.NombreCliente</p>
                    <p class="mb-1"><strong>Teléfono:</strong> @Model.Telefono</p>
                    <p class="mb-1"><strong>Dirección:</strong> @Model.Direccion</p>
                    <p class="mb-1"><strong>Fecha:</strong> @Model.FechaPedido.ToString("dd/MM/yyyy HH:mm")</p>
                    <p class="mb-0"><strong>Estado:</strong> <span class="badge bg-info text-dark">@Model.Estado</span></p>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white fw-bold">
                    Productos
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Producto</th>
                                <th>Precio</th>
                                <th>Cantidad</th>
                                <th class="text-end pe-3">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detalle in Model.Detalles)
                            {
                                <tr>
                                    <td class="ps-3">@detalle.Producto.Nombre</td>
                                    <td>Q @detalle.Producto.Precio</td>
                                    <td>@detalle.Cantidad</td>
                                    <td class="text-end pe-3 fw-bold">Q @(detalle.Producto.Precio * detalle.Cantidad)</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="3" class="text-end fw-bold">TOTAL:</td>
                                <td class="text-end pe-3 fw-bold text-success fs-5">Q @Model.Total</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>