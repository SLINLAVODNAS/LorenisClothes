@model LorenisClothes.Models.Pedido

@{
    ViewData["Title"] = "Detalle del Pedido";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">
            <i class="bi bi-receipt me-2"></i>Pedido #@Model.Id
        </h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver a la lista
        </a>
    </div>

    <div class="row">
        <!-- Información del Cliente -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-primary text-white fw-bold">
                    Datos del Cliente
                </div>
                <div class="card-body">
                    <p class="mb-1 text-muted small text-uppercase fw-bold">Nombre</p>
                    <p class="fs-5 fw-bold">@Model.NombreCliente</p>
                    
                    <p class="mb-1 text-muted small text-uppercase fw-bold">Teléfono</p>
                    <p class="fs-5">@Model.Telefono</p>
                    
                    <p class="mb-1 text-muted small text-uppercase fw-bold">Dirección de Entrega</p>
                    <p class="text-secondary">@Model.Direccion</p>

                    <hr />

                    <p class="mb-1 text-muted small text-uppercase fw-bold">Estado Actual</p>
                    <span class="badge @(Model.Estado == "Pendiente" ? "bg-warning" : "bg-success") fs-6 px-3">
                        @Model.Estado
                    </span>
                </div>
            </div>
        </div>

        <!-- Detalle de Productos -->
        <div class="col-md-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-dark text-white fw-bold">
                    Artículos del Pedido
                </div>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Producto</th>
                                <th class="text-center">Cantidad</th>
                                <th class="text-end">Precio Unit.</th>
                                <th class="text-end">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detalle in Model.Detalles)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            @if (!string.IsNullOrEmpty(detalle.Producto?.ImagenUrl))
                                            {
                                                <img src="@detalle.Producto.ImagenUrl" class="rounded me-3" style="width: 50px; height: 50px; object-fit: cover;" />
                                            }
                                            <span class="fw-bold">@detalle.Producto?.Nombre</span>
                                        </div>
                                    </td>
                                    <td class="text-center">@detalle.Cantidad</td>
                                    <td class="text-end">Q @detalle.PrecioUnitario.ToString("N2")</td>
                                    <td class="text-end fw-bold">Q @((detalle.Cantidad * detalle.PrecioUnitario).ToString("N2"))</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-group-divider">
                            <tr>
                                <td colspan="3" class="text-end fw-bold fs-5">TOTAL</td>
                                <td class="text-end fw-bold fs-5 text-primary">Q @Model.Total.ToString("N2")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            
            <div class="mt-4 p-3 bg-light rounded border">
                <p class="mb-0 text-muted small">
                    <i class="bi bi-calendar-event me-2"></i>
                    <strong>Fecha del Pedido:</strong> @Model.FechaPedido.ToString("f")
                </p>
            </div>
        </div>
    </div>
</div>