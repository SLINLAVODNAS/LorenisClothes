@model IEnumerable<LorenisClothes.Models.Pedido>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Gestión de Pedidos</h2>
        <a asp-controller="Productos" asp-action="Index" class="btn btn-outline-dark">
            Volver a Inventario
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-3">ID</th>
                        <th>Cliente</th>
                        <th>Fecha y Hora</th>
                        <th>Total</th>
                        <th>Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3 fw-bold">#@item.Id</td>
                            <td>@item.NombreCliente</td>
                            <td>@item.FechaPedido.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-success fw-bold">Q @item.Total</td>
                            <td>
                                <span class="badge bg-info text-dark">@item.Estado</span>
                            </td>
                            <td>
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary">
                                        Detalles
                                    </a>
                                    <form asp-action="Eliminar" asp-route-id="@item.Id" method="post" onsubmit="return confirm('¿Estás seguro de eliminar este registro?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            Eliminar
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>