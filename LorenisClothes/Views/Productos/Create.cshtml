@model LorenisClothes.Models.Producto

@{
    ViewData["Title"] = "Crear Producto";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white py-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-plus-circle me-2"></i>Crear Nuevo Producto</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label asp-for="Nombre" class="form-label fw-bold"></label>
                            <input asp-for="Nombre" class="form-control" placeholder="Nombre de la prenda" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Precio" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <span class="input-group-text">Q</span>
                                <input asp-for="Precio" class="form-control" type="number" step="0.01" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="Precio" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label fw-bold">Descripción</label>
                        <input asp-for="Descripcion" class="form-control" placeholder="Detalles del producto" />
                        <span asp-validation-for="Descripcion" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Color" class="form-label fw-bold"></label>
                            <input asp-for="Color" class="form-control" placeholder="Ej: Negro" />
                            <span asp-validation-for="Color" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Talla" class="form-label fw-bold"></label>
                            <input asp-for="Talla" class="form-control" placeholder="Ej: M, L, XL" />
                            <span asp-validation-for="Talla" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Stock" class="form-label fw-bold"></label>
                            <input asp-for="Stock" class="form-control" type="number" />
                            <span asp-validation-for="Stock" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Imagen del producto</label>
                        <input asp-for="ImagenArchivo" type="file" class="form-control" accept="image/*" />
                        <span asp-validation-for="ImagenArchivo" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Volver a la lista</a>
                        <button type="submit" class="btn btn-primary px-5 fw-bold">Guardar Producto</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}