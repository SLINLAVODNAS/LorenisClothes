@model IEnumerable<LorenisClothes.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <h1>Productos</h1>

    @if (Context.Session.GetString("Admin") != null)
    {
        <a asp-action="Create" class="btn btn-primary">
            Agregar Producto
        </a>
    }

</div>

<div class="row">

    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">

            <div class="card h-100 shadow-sm border-0">

                <img src="@item.ImagenUrl"
                     class="card-img-top"
                     style="height:300px; object-fit:cover;" />

                <div class="card-body">

                    <h5 class="card-title">
                        @item.Nombre
                    </h5>

                    <p class="card-text">
                        @item.Descripcion
                    </p>

                    <p>
                        <strong>Precio:</strong>
                        Q @item.Precio
                    </p>

                    <p>
                        <strong>Color:</strong>
                        @item.Color
                    </p>

                    <p>
                        <strong>Stock:</strong>
                        @item.Stock
                    </p>

                    @if (item.Stock <= 0)
                    {
                        <p class="text-danger">
                            Producto agotado
                        </p>
                    }

                </div>

                <div class="card-footer bg-white border-0 d-flex justify-content-between flex-wrap gap-2">

                    @if (Context.Session.GetString("Admin") != null)
                    {
                        <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-warning btn-sm">
                            Editar
                        </a>

                        <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-danger btn-sm">
                            Eliminar
                        </a>
                    }

                    <a asp-action="Details"
                           asp-route-id="@item.Id"
                           class="btn btn-info btn-sm">
                        Detalles
                    </a>

                    @if (item.Stock > 0)
                    {
                        <a asp-controller="Carrito"
                               asp-action="Agregar"
                               asp-route-id="@item.Id"
                               asp-route-nombre="@item.Nombre"
                               asp-route-precio="@item.Precio"
                               asp-route-imagenUrl="@item.ImagenUrl"
                               class="btn btn-success btn-sm">
                            Agregar al carrito
                        </a>
                    }
                    else
                    {
                        <button class="btn btn-secondary btn-sm" disabled>
                            Sin stock
                        </button>
                    }

                </div>

            </div>

        </div>
    }

</div>