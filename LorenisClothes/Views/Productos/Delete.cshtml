@model LorenisClothes.Models.Producto

@{
    ViewData["Title"] = "Eliminar Producto";
}

<h1 class="mb-4 text-danger">Eliminar Producto</h1>

<div class="card shadow-sm p-4">

    <h4 class="mb-4">
        ¿Seguro que deseas eliminar este producto?
    </h4>

    <div class="text-center mb-4">

        <img src="@Model.ImagenUrl"
             width="300"
             style="border-radius:15px; object-fit:cover;" />

    </div>

    <dl class="row">

        <dt class="col-sm-3">
            Nombre
        </dt>

        <dd class="col-sm-9">
            @Model.Nombre
        </dd>

        <dt class="col-sm-3">
            Descripción
        </dt>

        <dd class="col-sm-9">
            @Model.Descripcion
        </dd>

        <dt class="col-sm-3">
            Precio
        </dt>

        <dd class="col-sm-9">
            Q @Model.Precio
        </dd>

        <dt class="col-sm-3">
            Color
        </dt>

        <dd class="col-sm-9">
            @Model.Color
        </dd>

    </dl>

    <form asp-action="Delete" class="mt-4">

        <input type="hidden" asp-for="Id" />

        <input type="submit"
               value="Eliminar"
               class="btn btn-danger" />

        <a asp-action="Index"
               class="btn btn-secondary">
            Cancelar
        </a>

    </form>

</div>